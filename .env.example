# LocalRank — Environment Variables
# Copy to .env.local and fill in your values

# ─── Supabase ───
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Google Maps ───
# Get from: console.cloud.google.com → APIs & Services → Credentials
# Enable: Places API
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ─── Stripe ───
# Get from: dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Create products and prices in Stripe Dashboard, then paste Price IDs here:
STRIPE_PRICE_ID_PRO_MONTHLY=price_...
STRIPE_PRICE_ID_PRO_YEARLY=price_...

# ─── Resend (Email) ───
# Get from: resend.com → API Keys
RESEND_API_KEY=re_...
